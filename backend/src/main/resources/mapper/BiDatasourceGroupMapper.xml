<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.aibi.bi.mapper.BiDatasourceGroupMapper">

    <resultMap id="DatasourceGroupMap" type="com.aibi.bi.domain.BiDatasourceGroup">
        <id column="id" property="id"/>
        <result column="name" property="name"/>
        <result column="sort_order" property="sortOrder"/>
        <result column="created_at" property="createdAt"/>
    </resultMap>

    <select id="listAll" resultMap="DatasourceGroupMap">
        SELECT id, name, sort_order, created_at
        FROM bi_datasource_group
        ORDER BY sort_order, id
    </select>

    <select id="findById" resultMap="DatasourceGroupMap" parameterType="long">
        SELECT id, name, sort_order, created_at
        FROM bi_datasource_group
        WHERE id = #{id}
    </select>

    <insert id="insert" parameterType="com.aibi.bi.domain.BiDatasourceGroup" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO bi_datasource_group (name, sort_order)
        VALUES (#{name}, #{sortOrder})
    </insert>

    <update id="update" parameterType="com.aibi.bi.domain.BiDatasourceGroup">
        UPDATE bi_datasource_group
        SET name = #{name}, sort_order = #{sortOrder}
        WHERE id = #{id}
    </update>

    <delete id="deleteById" parameterType="long">
        DELETE FROM bi_datasource_group WHERE id = #{id}
    </delete>

</mapper>