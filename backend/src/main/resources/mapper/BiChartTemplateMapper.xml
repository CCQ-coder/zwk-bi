<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.aibi.bi.mapper.BiChartTemplateMapper">

    <resultMap id="TemplateMap" type="com.aibi.bi.domain.BiChartTemplate">
        <id     column="id"          property="id"/>
        <result column="name"        property="name"/>
        <result column="chart_type"  property="chartType"/>
        <result column="config_json" property="configJson"/>
        <result column="created_at"  property="createdAt"/>
    </resultMap>

    <select id="listAll" resultMap="TemplateMap">
        SELECT id, name, chart_type, config_json, created_at
        FROM bi_chart_template
        ORDER BY id ASC
    </select>

    <select id="findById" resultMap="TemplateMap" parameterType="long">
        SELECT id, name, chart_type, config_json, created_at
        FROM bi_chart_template
        WHERE id = #{id}
    </select>

    <insert id="insert" parameterType="com.aibi.bi.domain.BiChartTemplate"
            useGeneratedKeys="true" keyProperty="id">
        INSERT INTO bi_chart_template (name, chart_type, config_json)
        VALUES (#{name}, #{chartType}, #{configJson})
    </insert>

    <update id="update" parameterType="com.aibi.bi.domain.BiChartTemplate">
        UPDATE bi_chart_template
        SET name = #{name}, chart_type = #{chartType}, config_json = #{configJson}
        WHERE id = #{id}
    </update>

    <delete id="deleteById" parameterType="long">
        DELETE FROM bi_chart_template WHERE id = #{id}
    </delete>

</mapper>
